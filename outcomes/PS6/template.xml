        <!-- {{#tasks}} -->
        <knowl>
            
            <knowl>
                <content>
                    <p>
                        Find the closed form for  <m>\renewcommand{\log}{\ln}\displaystyle \sum_{n = {{k2}} }^\infty {{Ax}} </m>.
                    </p>
                </content>
                <outtro>
                    <p>
                        Since <m>\renewcommand{\log}{\ln}  \displaystyle {{fx}} = \sum_{ n = {{k1}} }^\infty {{ax}}</m>,
                        we have that <m>\renewcommand{\log}{\ln}\displaystyle {{Fx}} =  \sum_{ n = {{k0}} }^\infty {{Ax}}</m>,
                        and <m>\renewcommand{\log}{\ln}\displaystyle  \sum_{ n = {{k2}} }^\infty {{Ax}} = {{FFx}}</m>.
                    </p>
                </outtro>
            </knowl>
            

            

            
        </knowl>
